  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "rss-parser": "^3.13.0",
    "sqlite3": "^5.1.7"
  }
}
