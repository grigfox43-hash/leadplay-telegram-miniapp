# Server Port
PORT=8080

# Telegram Bot Token from @BotFather (Required for Telegram bot alerts)
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL of the Mini App (Vercel / Cloudflare / Ngrok / Domain)
MINI_APP_URL=http://localhost:8080

# Continuous order search interval in minutes (default: 5)
POLL_INTERVAL_MINUTES=5
