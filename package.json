{
  "name": "leadplay-telegram-miniapp",
  "version": "1.0.0",
  "description": "Continuous order search system for Telegram Mini App",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
